# =========================
# Dependencies
# =========================
node_modules/
**/node_modules/

# =========================
# Build outputs
# =========================
dist/
build/
out/

# TypeScript build info
*.tsbuildinfo

# =========================
# Environment variables
# IMPORTANT: never commit secrets
# =========================
.env
.env.*
!.env.example

# =========================
# Logs
# =========================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# =========================
# OS files
# =========================
.DS_Store
Thumbs.db

# =========================
# IDE / Editor
# =========================
.vscode/
.idea/
*.swp

# =========================
# Docker
# =========================
docker-compose.override.yml

# =========================
# Coverage reports (testing)
# =========================
coverage/

# =========================
# Runtime data
# =========================
pids/
*.pid
*.seed
*.pid.lock

# =========================
# Optional: Kafka / local infra files
# =========================
kafka-logs/
zookeeper-data/

# =========================
# Misc
# =========================
.tmp/
.temp/

